# Jira Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to git!

# Jira Server URL (e.g., https://your-company.atlassian.net)
JIRA_SERVER=https://your-jira-instance.atlassian.net

# Jira Email (your Jira account email)
JIRA_EMAIL=your-email@example.com

# Jira API Token (generate from: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=your-api-token-here

# Default Project Key (e.g., PROJ, ODF, etc.)
JIRA_PROJECT_KEY=YOUR_PROJECT_KEY

# Jenkins Configuration
# Jenkins Job URL (full URL to the Jenkins job)
# Example: https://your-jenkins-server.com/job/project/job/branch/job/build-job
JENKINS_URL=https://your-jenkins-server.com/job/your-job-path

# Jenkins Username
JENKINS_USER=your-jenkins-username

# Jenkins API Token (generate from: Jenkins > User > Configure > API Token)
JENKINS_API_TOKEN=your-jenkins-api-token

# Google Drive Configuration
# Parent folder ID where version-specific folders will be created
# Example: 17TvbLfm--fvpeBbnQvAnX
GOOGLE_DRIVE_PARENT_FOLDER_ID=your-parent-folder-id

# Path to Google Drive service account credentials JSON file
# Default: google_drive_service_account_creds.json
GOOGLE_DRIVE_CREDENTIALS_FILE=google_drive_service_account_creds.json

# (Optional) User email for domain-wide delegation
# Service accounts don't have storage quota. To upload files:
# Option 1: Use a Shared Drive (recommended) - set parent folder to a Shared Drive folder
# Option 2: Use domain-wide delegation - set this to a user email with storage quota
# Example: user@your-domain.com
# Leave empty if using Shared Drive
GDRIVE_USER_EMAIL=