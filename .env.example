# Jira Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to git!

# Jira Server URL (e.g., https://your-company.atlassian.net)
JIRA_SERVER=https://your-jira-instance.atlassian.net

# Jira Email (your Jira account email)
JIRA_EMAIL=your-email@example.com

# Jira API Token (generate from: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=your-api-token-here

# Default Project Key (e.g., PROJ, ODF, etc.)
JIRA_PROJECT_KEY=YOUR_PROJECT_KEY

# Jenkins Configuration
# Jenkins Job URL (full URL to the Jenkins job)
# Example: https://your-jenkins-server.com/job/project/job/branch/job/build-job
JENKINS_URL=https://your-jenkins-server.com/job/your-job-path

# Jenkins Username
JENKINS_USER=your-jenkins-username

# Jenkins API Token (generate from: Jenkins > User > Configure > API Token)
JENKINS_API_TOKEN=your-jenkins-api-token

# Google Drive Configuration (for upload_must_gather_to_gdrive.py)
# Parent folder ID — the last segment of the shared folder URL:
#   https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_PARENT_FOLDER_ID=your-google-drive-folder-id

# OAuth 2.0 client secrets JSON downloaded from Google Cloud Console.
# Steps to create:
#   1. https://console.cloud.google.com/ → APIs & Services → Enable "Google Drive API"
#   2. Credentials → Create Credentials → OAuth client ID → Desktop app
#   3. Download JSON → save as oauth_client_secrets.json (next to the script)
GDRIVE_OAUTH_CLIENT_FILE=oauth_client_secrets.json

# Where the script caches the OAuth token after first login (auto-created).
# Do NOT commit this file to git.
GDRIVE_OAUTH_TOKEN_FILE=.gdrive_oauth_token.json