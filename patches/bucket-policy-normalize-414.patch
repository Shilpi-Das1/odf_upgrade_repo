+def extract_policy_actions(policy_json):
+    """
+    Support AWS (Statement/Action) and NooBaa (statement/action)
+    Normalize to lowercase without s3: prefix
+    """
+    statements = policy_json.get("Statement") or policy_json.get("statement")
+    assert statements, f"No statement found in policy: {policy_json}"
+
+    actions = statements[0].get("Action") or statements[0].get("action")
+    assert actions, f"No actions found in policy: {statements[0]}"
+
+    return [
+        action.split("s3:", 1)[1].lower()
+        for action in actions
+        if action.startswith("s3:")
+    ]
+
+
 @mcg
 @red_squad
 @runs_on_provider
