 log = logging.getLogger(__name__)
 
 
+def wait_for_component_running_by_label(
+    label_key,
+    label_value,
+    namespace="openshift-storage",
+    timeout=300,
+    sleep=10,
+):
+    """
+    Wait until at least one pod with the given label key/value is Running.
+
+    This uses fresh Kubernetes discovery every iteration and does NOT rely
+    on cached pod names. It is safe during rolling updates and node failure.
+    """
+    ocp = OCP(kind="Pod", namespace=namespace)
+    end_time = time.time() + timeout
+
+    
+    while time.time() < end_time:
+        pod_list = ocp.get().get("items", [])
+
+        for pod in pod_list:
+            metadata = pod.get("metadata", {})
+            labels = metadata.get("labels", {})
+            phase = pod.get("status", {}).get("phase", "")
+
+            if labels.get(label_key) == label_value and phase == "Running":
+                log.info(f"Found Running pod {metadata.get('name')} "
+                         f"for {label_key}={label_value}")
+                return True
+
+        log.info(f"Waiting for {label_key}={label_value} to have a Running pod...")
+        time.sleep(sleep)
+
+    return False
